# ----- Neon Postgres -----
# Pooled connection (runtime). Use the "-pooler" host from the Neon dashboard.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.eu-central-1.aws.neon.tech/enamel?sslmode=require"
# Direct connection (migrations).
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.eu-central-1.aws.neon.tech/enamel?sslmode=require"

# ----- Neon Auth (Stack Auth) -----
NEXT_PUBLIC_STACK_PROJECT_ID="your-stack-project-id"
NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY="your-publishable-client-key"
STACK_SECRET_SERVER_KEY="your-secret-server-key"

# ----- Resend (email) -----
RESEND_API_KEY="re_xxxxxxxx"
EMAIL_FROM="Enamel <noreply@enamel.ba>"
CONTACT_TO_EMAIL="info@enamel.ba"

# Comma-separated emails allowed into the admin dashboard.
ADMIN_EMAILS="info@enamel.ba"

# Public site URL (used for absolute links / metadata).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
